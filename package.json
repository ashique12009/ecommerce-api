{
  "name": "ecommerce-api",
  "version": "1.0.0",
  "description": "An e-commerce API built with Node.js, Express, and Sequelize",
  "main": "server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "TZ=Europe/Helsinki node server.js",
    "dev": "TZ=Europe/Helsinki nodemon server.js",
    "migrate": "node -r dotenv/config node_modules/.bin/sequelize db:migrate",
    "migrate:undo": "node -r dotenv/config node_modules/.bin/sequelize db:migrate:undo",
    "seed": "node -r dotenv/config node_modules/.bin/sequelize db:seed:all",
    "seed:undo": "node -r dotenv/config node_modules/.bin/sequelize db:seed:undo:all",
    "migrate:undo:all": "node -r dotenv/config node_modules/.bin/sequelize db:migrate:undo:all",
    "db:fresh": "node -r dotenv/config node_modules/.bin/sequelize db:drop && node -r dotenv/config node_modules/.bin/sequelize db:create && npm run migrate && npm run seed"
  },
  "keywords": [],
  "author": "Ashique Mahamud",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5"
  }
}
